# Kilmurry Gateway — secrets.toml (DO NOT COMMIT)
# Copy this file to secrets.toml. config/secrets.toml is gitignored.
#
# Values here are exported as environment variables at startup
# (e.g. client_secret -> REZLYNX_CLIENT_SECRET) so adapter code can
# read them with os.getenv without re-reading TOML.

[rezlynx]
client_secret = "PUT_REAL_CLIENT_SECRET_HERE_ONCE_ISSUED"
password = ""
api_key = ""
